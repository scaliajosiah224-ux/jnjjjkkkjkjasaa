# ─────────────── Config ───────────────
MONGO_URL = os.environ.get("MONGO_URL", "mongodb://localhost:27017")
JWT_SECRET = os.environ.get("JWT_SECRET", "ringring_secret_2025")
JWT_ALGORITHM = os.environ.get("JWT_ALGORITHM", "HS256")
JWT_EXP_HOURS = int(os.environ.get("JWT_EXPIRATION_HOURS", "24"))

SINCH_PROJECT_ID = os.environ.get("SINCH_PROJECT_ID", "")
SINCH_ACCESS_KEY_ID = os.environ.get("SINCH_ACCESS_KEY_ID", "")
SINCH_KEY_SECRET = os.environ.get("SINCH_KEY_SECRET", "")
SINCH_SERVICE_PLAN_ID = os.environ.get("SINCH_SERVICE_PLAN_ID", "")
SINCH_SMS_API_TOKEN = os.environ.get("SINCH_SMS_API_TOKEN", "")
SINCH_APP_KEY = os.environ.get("SINCH_APP_KEY", "")
SINCH_APP_SECRET = os.environ.get("SINCH_APP_SECRET", "")
