@app.post("/api/messages/read")
async def mark_as_read(req: ReadReceiptRequest, user=Depends(get_current_user)):
    """Mark messages as read."""
    await db.messages.update_many(
        {"conversation_id": req.conversation_id, "direction": "inbound", "status": {"$ne": "read"}},
        {"$set": {"status": "read", "read_at": datetime.utcnow().isoformat()}}
    )
    await db.conversations.update_one(
        {"id": req.conversation_id},
        {"$set": {"unread_count": 0}}
    )
    # Notify sender
    await manager.send_to_user(user["id"], {
        "type": "messages_read",
        "conversation_id": req.conversation_id
    })
    return {"status": "ok"}

# ─────────────── MESSAGE REACTION ───────────────
@app.post("/api/messages/react")
async def react_to_message(req: ReactToMessageRequest, user=Depends(get_current_user)):
    """Add emoji reaction to a message."""
    msg = await db.messages.find_one({"id": req.message_id})
    if not msg:
        raise HTTPException(status_code=404, detail="Message not found")
    
    reactions = msg.get("reactions", {})
    if req.emoji not in reactions:
        reactions[req.emoji] = []
    
    if user["id"] in reactions[req.emoji]:
        reactions[req.emoji].remove(user["id"])
    else:
        reactions[req.emoji].append(user["id"])
    
    await db.messages.update_one(
        {"id": req.message_id},
        {"$set": {"reactions": reactions}}
    )
    return {"reactions": reactions}

